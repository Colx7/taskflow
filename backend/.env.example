# 应用名
APP_NAME=TaskFlow
DEBUG=true

# 数据库
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=taskflow

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_EXPIRE_DAYS=7

# AI (通义千问/DashScope)
DASHSCOPE_API_KEY=sk-your-api-key-here
AI_MODEL=qwen-plus
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2048
AI_TIMEOUT=30
